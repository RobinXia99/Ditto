# =============================================================================
# LLM Providers — set the key(s) for the provider(s) you want to use
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=...

# =============================================================================
# LLM Task Routing — pick a provider + model per task
# Defaults: claude / claude-sonnet-4-20250514 for both
# =============================================================================
# LLM_INTENT_PROVIDER=gemini
# LLM_INTENT_MODEL=gemini-2.5-flash
# LLM_ANALYSIS_PROVIDER=claude
# LLM_ANALYSIS_MODEL=claude-sonnet-4-20250514

# --- Preset: cheapest (Gemini Flash for everything) ---
# LLM_INTENT_PROVIDER=gemini
# LLM_INTENT_MODEL=gemini-2.5-flash
# LLM_ANALYSIS_PROVIDER=gemini
# LLM_ANALYSIS_MODEL=gemini-2.5-flash

# --- Preset: best mix (cheap intent, strong analysis) ---
# LLM_INTENT_PROVIDER=gemini
# LLM_INTENT_MODEL=gemini-2.5-flash
# LLM_ANALYSIS_PROVIDER=claude
# LLM_ANALYSIS_MODEL=claude-sonnet-4-20250514

# =============================================================================
# GitHub (optional — falls back to keychain)
# =============================================================================
GITHUB_TOKEN=ghp_...

# =============================================================================
# Picovoice (required for wake word)
# =============================================================================
PICOVOICE_ACCESS_KEY=...

# Wake word
WAKE_WORD=porcupine
# Or path to custom .ppn file:
# WAKE_WORD_MODEL_PATH=./models/ditto.ppn

# =============================================================================
# Whisper (local STT)
# =============================================================================
WHISPER_MODEL_PATH=./models/ggml-base.en.bin

# =============================================================================
# TTS
# =============================================================================
TTS_ENGINE=macos-say
# TTS_ENGINE=piper
# PIPER_MODEL_PATH=./models/en_US-lessac-medium.onnx

# =============================================================================
# Recording
# =============================================================================
SILENCE_THRESHOLD=500
SILENCE_DURATION_MS=1500
MAX_RECORDING_MS=10000
SAMPLE_RATE=16000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=debug
